{
  "compilerOptions": {
    /* Layout do Projeto */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Configurações de Ambiente */
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "skipLibCheck": true,

    /* Interoperabilidade e Rigor */
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,

    /* Mapas de Origem (ajuda no Debug) */
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
